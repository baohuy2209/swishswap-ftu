model SwapPreference {
  id          String   @id @default(cuid())
  listing_id  String
  category_id String?
  keyword     String?
  created_at  DateTime @default(now())

  listing  Listing   @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [category_id], references: [id])

  @@index([listing_id])
  @@map("swap_preferences")
}

enum OrderStatus {
  pending_payment
  payment_submitted
  payment_confirmed
  pickup_confirmed
  completed
  cancelled
  disputed
}

enum PaymentMethod {
  bank_transfer
  cash
}

enum FulfillmentMethod {
  meetup
  delivery
}

model Order {
  id           String @id @default(cuid())
  order_number String @unique

  // Parties
  buyer_id   String
  seller_id  String
  listing_id String
  offer_id   String @unique

  // Order details
  status             OrderStatus       @default(pending_payment)
  payment_method     PaymentMethod
  fulfillment_method FulfillmentMethod

  // Amounts
  item_price      Decimal @db.Decimal(12, 2)
  transaction_fee Decimal @db.Decimal(12, 2) // 5%
  total_amount    Decimal @db.Decimal(12, 2)

  // Payment
  payment_proof_url    String?
  payment_submitted_at DateTime?
  payment_confirmed_at DateTime?

  // Cash confirmation (both parties must confirm)
  buyer_cash_confirmed  Boolean   @default(false)
  seller_cash_confirmed Boolean   @default(false)
  cash_confirmed_at     DateTime?

  // Fulfillment
  pickup_location     String?
  pickup_time         DateTime?
  pickup_confirmed_at DateTime?

  // Deadlines
  confirmation_deadline DateTime

  // Timestamps
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  completed_at DateTime?
  cancelled_at DateTime?

  // Relations
  listing Listing @relation(fields: [listing_id], references: [id])
  offer   Offer   @relation(fields: [offer_id], references: [id])
  review  Review?
  user    User?   @relation(fields: [userId], references: [id])
  userId  String?

  @@index([buyer_id])
  @@index([seller_id])
  @@index([listing_id])
  @@index([status])
  @@index([created_at])
  @@map("orders")
}

model Review {
  id          String @id @default(cuid())
  order_id    String @unique
  author_id   String
  receiver_id String

  rating  Int // 1-5 stars
  comment String? @db.VarChar(500)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  order    Order @relation(fields: [order_id], references: [id])
  author   User  @relation("AuthorId", fields: [author_id], references: [id])
  receiver User  @relation("ReceiverId", fields: [receiver_id], references: [id])

  @@index([receiver_id])
  @@index([created_at])
  @@map("reviews")
}

enum OfferStatus {
  pending
  accepted
  declined
  countered
  expired
}

enum OfferType {
  buy
  swap
}

model Offer {
  id          String @id @default(cuid())
  listing_id  String
  sender_id   String
  receiver_id String

  offer_type OfferType
  status     OfferStatus @default(pending)

  // Buy offer
  price_offered Decimal? @db.Decimal(12, 2)

  // Swap offer
  cash_topup Decimal? @db.Decimal(12, 2)

  // Pickup/delivery
  pickup_location String?
  pickup_time     DateTime?

  // Timestamps
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  expires_at   DateTime?
  responded_at DateTime?

  // Relations
  listing  Listing @relation(fields: [listing_id], references: [id])
  sender   User    @relation("OfferSender", fields: [sender_id], references: [id])
  receiver User    @relation("OfferReceiver", fields: [receiver_id], references: [id])
  order    Order?

  @@index([listing_id])
  @@index([sender_id])
  @@index([created_at])
  @@map("offers")
}
