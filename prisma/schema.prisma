// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/**
 * Auth & Users
 * User profiles với email verification (.edu domain)
 * Trust metrics (rating, verification status)
 * Zone và University relationships
 */

model User {
  id               String           @id @default(cuid())
  name             String
  email            String           @unique
  email_verified   Boolean          @default(false)
  password_hash    String
  phone            String
  location         String?
  university_id    String
  avatar_url       String?
  evidence_url     String?
  rating_count     Int              @default(5)
  review_count     Int              @default(0)
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  university_name  String?
  listings         Listing[]
  orders           Order[]
  received_reviews Review[]         @relation("ReceiverId")
  offers_receiver  Offer[]          @relation("OfferReceiver")
  sessions         Session[]
  swapPreferences  SwapPreference[]
  billings         Billing[]
}

model Session {
  id        String   @id @unique
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model University {
  id         String   @id @default(cuid())
  label      String   @unique
  value      String   @unique
  zone       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([value])
  @@map("universities")
}

model Category {
  id         String   @id @default(cuid())
  name       String   @unique
  slug       String   @unique
  group      String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  listings   Listing[]
  swap_prefs SwapPreference[]

  @@map("categories")
}

enum ListingStatus {
  draft
  available
  reserved
  completed
  cancelled
}

enum ListingCondition {
  new
  like_new
  good
  fair
}

model Listing {
  id            String @id @default(cuid())
  seller_id     String
  university_id String
  category_id   String

  // Basic Info
  title       String
  description String           @db.Text
  condition   ListingCondition
  price       Decimal          @db.Decimal(12, 2)
  status      ListingStatus    @default(draft)

  // Location
  location String

  // Swap
  swap_enabled Boolean @default(true)

  // Metrics
  view_count     Int @default(0)
  favorite_count Int @default(0)

  // Timestamps
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  published_at DateTime?
  reserved_at  DateTime?
  completed_at DateTime?

  // Relations
  seller        User             @relation(fields: [seller_id], references: [id])
  category      Category         @relation(fields: [category_id], references: [id])
  // media      ListingMedia[]
  swap_prefs    SwapPreference[]
  offers        Offer[]
  orders        Order[]
  listingMedias ListingMedia[]

  @@index([seller_id])
  @@index([university_id])
  @@index([category_id])
  @@index([status])
  @@index([created_at])
  @@index([price])
  @@map("listings")
}

model ListingMedia {
  id            String   @id @default(cuid())
  listing_id    String
  images_url    String
  is_main_image Boolean  @default(false)
  created_at    DateTime @default(now())

  listing Listing @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@index([listing_id])
  @@map("listing_media")
}

enum SwapPreferenceStatus {
  pending
  accepted
  declined
}

model SwapPreference {
  id              String               @id @default(cuid())
  listing_id      String
  category_id     String
  sender_id       String
  product_name    String
  product_price   Decimal?             @db.Decimal(12, 2)
  product_status  String
  Note            String
  pickup_location String?
  pickup_time     DateTime?
  status          SwapPreferenceStatus @default(pending)
  created_at      DateTime             @default(now())
  updated_at      DateTime             @updatedAt

  listing  Listing   @relation(fields: [listing_id], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [category_id], references: [id])
  user     User      @relation(fields: [sender_id], references: [id])

  @@index([listing_id])
  @@map("swap_preferences")
}

enum OrderStatus {
  pending_payment
  payment_submitted
  payment_confirmed
  pickup_confirmed
  completed
  cancelled
  disputed
}

enum PaymentMethod {
  bank_transfer
  cash
}

enum FulfillmentMethod {
  meetup
  delivery
}

model Order {
  id           String @id @default(cuid())
  order_number String @unique

  // Parties
  buyer_id   String
  seller_id  String
  listing_id String
  offer_id   String @unique

  // Order details
  status             OrderStatus       @default(pending_payment)
  payment_method     PaymentMethod     @default(cash)
  fulfillment_method FulfillmentMethod @default(meetup)

  // Amounts
  item_price      Decimal @db.Decimal(12, 2)
  transaction_fee Decimal @db.Decimal(12, 2) // 5%
  total_amount    Decimal @db.Decimal(12, 2)

  // Payment
  payment_proof_url    String?
  payment_submitted_at DateTime?
  payment_confirmed_at DateTime?

  // Cash confirmation (both parties must confirm)
  buyer_cash_confirmed  Boolean   @default(false)
  seller_cash_confirmed Boolean   @default(false)
  cash_confirmed_at     DateTime?

  // Fulfillment
  pickup_location     String?
  pickup_time         DateTime?
  pickup_confirmed_at DateTime?

  // Timestamps
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  completed_at DateTime?
  cancelled_at DateTime?

  // Relations
  listing Listing @relation(fields: [listing_id], references: [id])
  review  Review?
  user    User?   @relation(fields: [userId], references: [id])
  userId  String?
  offers  Offer[]

  @@index([buyer_id])
  @@index([seller_id])
  @@index([listing_id])
  @@index([status])
  @@index([created_at])
  @@map("orders")
}

model Review {
  id          String @id @default(cuid())
  order_id    String @unique
  receiver_id String

  rating  Int // 1-5 stars
  comment String? @db.VarChar(500)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  order    Order @relation(fields: [order_id], references: [id])
  receiver User  @relation("ReceiverId", fields: [receiver_id], references: [id])

  @@index([receiver_id])
  @@index([created_at])
  @@map("reviews")
}

enum OfferStatus {
  pending
  accepted
  declined
  countered
  expired
}

model Offer {
  id         String @id @default(cuid())
  listing_id String
  sender_id  String

  status OfferStatus @default(pending)

  // Buy offer
  price_offered   Decimal? @db.Decimal(12, 2)
  // Pickup/delivery
  pickup_location String
  pickup_time     DateTime
  note            String?

  // Timestamps
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  expires_at   DateTime?
  responded_at DateTime?

  // Relations
  listing Listing @relation(fields: [listing_id], references: [id])
  sender  User    @relation("OfferReceiver", fields: [sender_id], references: [id])
  order   Order?  @relation(fields: [orderId], references: [id])
  orderId String?

  @@index([listing_id])
  @@index([sender_id])
  @@index([created_at])
  @@map("offers")
}

enum BillingFeeType {
  buy_sell
  exchange
}

enum BillingStatus {
  pending
  paid
}

model Billing {
  id String @id @default(cuid())

  user_id  String
  order_id String?

  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("VND")

  fee_type BillingFeeType
  status   BillingStatus  @default(pending)

  invoice_url String?

  created_at DateTime  @default(now())
  paid_at    DateTime?

  user User @relation(fields: [user_id], references: [id])
}
