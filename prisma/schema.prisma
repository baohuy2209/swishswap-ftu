generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/**
 * Auth & Users
 * User profiles với email verification (.edu domain)
 * Trust metrics (rating, verification status)
 * Zone và University relationships
 */

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  email_verified   Boolean   @default(false)
  password_hash    String
  phone            String?
  university_id    String?
  zone_id          String?
  rating_count     Int       @default(0)
  review_count     Int       @default(0)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  zoneId           String?
  university_name  String?
  listings         Listing[]
  orders           Order[]
  zone             Zone?     @relation(fields: [zoneId], references: [id])
  authored_reviews Review[]  @relation("AuthorId")
  received_reviews Review[]  @relation("ReceiverId")
  offers_sender    Offer[]   @relation("OfferSender")
  offers_receiver  Offer[]   @relation("OfferReceiver")
  sessions         Session[]
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Zone {
  id              String   @id @default(cuid())
  name            String   @unique // e.g., "HCMC", "Hanoi"
  slug            String   @unique
  university_name String
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  users User[]

  @@map("zones")
}

model University {
  id         String   @id @default(cuid())
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("universities")
}

model Category {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  icon       String?
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  listings   Listing[]
  swap_prefs SwapPreference[]

  @@map("categories")
}

enum ListingStatus {
  draft
  available
  reserved
  completed
  cancelled
}

enum ListingCondition {
  new
  like_new
  good
  fair
}

model Listing {
  id            String @id @default(cuid())
  seller_id     String
  university_id String
  category_id   String

  // Basic Info
  title       String
  description String           @db.Text
  condition   ListingCondition
  price       Decimal          @db.Decimal(12, 2)
  status      ListingStatus    @default(draft)

  // Location
  location String

  // Swap
  swap_enabled Boolean @default(false)
  swap_only    Boolean @default(false)

  // Metrics
  view_count     Int @default(0)
  favorite_count Int @default(0)

  // Timestamps
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  published_at DateTime?
  reserved_at  DateTime?
  completed_at DateTime?

  // Relations
  seller     User             @relation(fields: [seller_id], references: [id])
  category   Category         @relation(fields: [category_id], references: [id])
  // media      ListingMedia[]
  swap_prefs SwapPreference[]
  offers     Offer[]
  orders     Order[]

  @@index([seller_id])
  @@index([university_id])
  @@index([category_id])
  @@index([status])
  @@index([created_at])
  @@index([price])
  @@map("listings")
}

